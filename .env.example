# Database
DATABASE_URL="postgresql://hkuseat:hkuseat123@localhost:5432/hkuseat?schema=public"

# JWT
JWT_SECRET="change-me-to-a-secure-random-string-in-production"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# QR Code
QR_SECRET="change-me-qr-secret-for-signing"

# App Config
CHECKIN_TIMEOUT_MINUTES="60"          # Initial session length, also extension length per call
CHECKIN_MAX_EXTENSIONS="3"            # Max extensions per check-in (prevents seat hogging)
CHECKIN_GRACE_SECONDS="60"            # Grace period after expiresAt before auto-checkout
CHECKIN_NOTIFY_BEFORE_MINUTES="10"    # Push reminder this many minutes before session expires
FAVORITE_NOTIFY_OCCUPANCY_PCT="80"    # Notify favorite watchers when occupancy < this %
FAVORITE_NOTIFY_COOLDOWN_MINUTES="30" # Per-favorite cooldown between alerts
API_PORT="3001"
ADMIN_PORT="3000"

# Expo Push API (optional - only required at higher throughput)
# EXPO_ACCESS_TOKEN=""

# CORS
CORS_ORIGIN="http://localhost:3000,exp://192.168.1.100:8081"

# Rate Limiting
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
